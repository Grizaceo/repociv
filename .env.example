# RepoCiv Bridge
REPOCIV_PORT=5277
BRIDGE_PORT=5274
VITE_PORT=5277
# Dejar vacío = dev mode (auth bypass). En producción: token aleatorio de 32+ chars.
# Generar con: python3 -c "import secrets; print(secrets.token_hex(32))"
REPOCIV_TOKEN=

# Workspace paths — absolutas o con ~ (se expanden con expanduser)
# Mapa Imperial (Vite): carpetas hijas directas de esta ruta = ciudades. Prioridad: REPOCIV_MAP_ROOT > WORKSPACE_ROOT > REPOCIV_REPOS_ROOT > ~/.hermes/workspace/repos
# WSL (equivalente \\wsl.localhost\Ubuntu\home\gris): REPOCIV_MAP_ROOT=/home/gris
REPOCIV_MAP_ROOT=
WORKSPACE_ROOT=~/.hermes/workspace/repos
HERMES_ROOT=~/.hermes
REPOCIV_REPOS_ROOT=/home/gris/.hermes/workspace/repos

# Hermes Agent API
HERMES_URL=http://localhost:8642/v1/chat/completions
HERMES_MODEL=minimax-m2.6
REPOCIV_CONFIG_DIR=~/.repociv
