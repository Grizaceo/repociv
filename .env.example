# RepoCiv Bridge
REPOCIV_PORT=5277
BRIDGE_PORT=5274
VITE_PORT=5277
# Auth token — dejar vacío = dev mode (auth bypass). En producción: token aleatorio de 32+ chars.
# Generar con: python3 -c "import secrets; print(secrets.token_hex(32))"
REPOCIV_TOKEN=

# Remote mode via Tailscale
# Set REPOCIV_REMOTE=true AND REPOCIV_TOKEN to expose the bridge on 0.0.0.0.
# WARNING: In remote mode, REPOCIV_TOKEN is REQUIRED. The bridge will REFUSE to
# start if REPOCIV_REMOTE=true is set without a token.
# REPOCIV_REMOTE=true
# REPOCIV_REMOTE_TOKEN=<paste generated token here>

# Workspace paths — absolutas o con ~ (se expanden con expanduser)
# Mapa Imperial (Vite): carpetas hijas directas de esta ruta = ciudades. Prioridad: REPOCIV_MAP_ROOT > WORKSPACE_ROOT > REPOCIV_REPOS_ROOT > ~/.hermes/workspace/repos
# WSL (equivalente \\wsl.localhost\Ubuntu\home\gris): REPOCIV_MAP_ROOT=/home/gris
REPOCIV_MAP_ROOT=
WORKSPACE_ROOT=~/.hermes/workspace/repos
HERMES_ROOT=~/.hermes
REPOCIV_REPOS_ROOT=/home/gris/.hermes/workspace/repos

# Hermes Agent API
HERMES_URL=http://localhost:8642/v1/chat/completions
HERMES_MODEL=minimax-m2.6
REPOCIV_CONFIG_DIR=~/.repociv

# Maravilla Bibliotheca (La Gran Biblioteca)
# UI: host:puerto donde abres LGB en el navegador (Vite :5173)
VITE_WONDER_BIBLIOTHECA_URL=http://127.0.0.1:5173
# Health-check del bridge — casi siempre 127.0.0.1:3001 aunque la UI sea IP Tailscale
VITE_LGB_BACKEND_URL=http://127.0.0.1:3001
# Tailscale UI: VITE_WONDER_BIBLIOTHECA_URL=http://<ip>:5173 (backend health sigue en 127.0.0.1 si mismo PC/WSL)
# Docker LGB: VITE_WONDER_BIBLIOTHECA_URL=http://127.0.0.1:3000
