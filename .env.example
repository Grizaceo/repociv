# RepoCiv — Configuración de entorno
# Copiar a .env y ajustar

# Puertos
VITE_PORT=5273
BRIDGE_PORT=5274
REPOCIV_PORT=5273

# Seguridad — token compartido entre bridge.py y el frontend
# Generar con: python3 -c "import secrets; print(secrets.token_hex(32))"
# Dejar vacío para deshabilitar auth (solo en desarrollo local)
REPOCIV_TOKEN=
VITE_BRIDGE_TOKEN=

# Rutas
WORKSPACE_ROOT=~/.hermes/workspace/repos
HERMES_ROOT=~/.hermes
REPOCIV_CONFIG_DIR=~/.repociv

# Hermes API
HERMES_URL=http://localhost:8642/v1/chat/completions
HERMES_KEY=davi-voice-bridge-2026
HERMES_MODEL=minimax-m2.6
