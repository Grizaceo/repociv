# RepoCiv Bridge
REPOCIV_PORT=5273
# Capital city display name shown in the panel header.
# If a folder in your workspace has this name (lowercased), it becomes the capital
# instead of a regular city tile.
# VITE_CAPITAL_NAME=Capital
BRIDGE_PORT=5274
BRIDGE_WS_PORT=5275
VITE_PORT=5273
# Frontend needs the same token as the bridge when REPOCIV_TOKEN is set.
VITE_REPOCIV_TOKEN=${VITE_REPOCIV_TOKEN:-}
# Auth token — dejar vacío = dev mode local (auth bypass). En remoto: token aleatorio de 32+ chars.
# Generar con: python3 -c "import secrets; print(secrets.token_hex(32))"
REPOCIV_TOKEN=

# Remote mode via Tailscale
# Set REPOCIV_REMOTE=true AND REPOCIV_TOKEN to expose the bridge on 0.0.0.0.
# WARNING: In remote mode, REPOCIV_TOKEN is REQUIRED. The bridge will REFUSE to
# start if REPOCIV_REMOTE=true is set without a token.
# REPOCIV_REMOTE_ORIGIN restricts CORS to a specific origin (e.g. Tailscale IP).
# Omitting it allows localhost only. Do NOT leave blank in production remote mode.
# REPOCIV_REMOTE=true
# REPOCIV_REMOTE_ORIGIN=http://<tailscale-ip>:5273
# REPOCIV_CORS_ORIGINS — comma-separated extra allowed CORS origins. Use this for
# WSL2 / Tailscale setups where the browser hits the bridge at the WSL2 external
# IP (e.g. http://100.123.206.92:5273) without enabling full remote mode.
# Example: REPOCIV_CORS_ORIGINS=http://100.123.206.92:5273
# REPOCIV_CORS_ORIGINS=

# Workspace paths — absolutas o con ~ (se expanden con expanduser)
# Mapa Imperial (Vite): carpetas hijas directas de esta ruta = ciudades. Prioridad: REPOCIV_MAP_ROOT > WORKSPACE_ROOT > REPOCIV_REPOS_ROOT > ~/.hermes/workspace/repos
# Ejemplo WSL/Linux: REPOCIV_MAP_ROOT=~/workspace
REPOCIV_MAP_ROOT=
WORKSPACE_ROOT=~/.hermes/workspace/repos
HERMES_ROOT=~/.hermes
REPOCIV_REPOS_ROOT=~/.hermes/workspace/repos

# Hermes Agent API
HERMES_URL=http://localhost:8642/v1/chat/completions
HERMES_MODEL=minimax-m2.6
REPOCIV_CONFIG_DIR=~/.repociv

# ── Maravillas (Wonders) ──────────────────────────────────────────────────────
# NADA viene pre-instalado: el mapa arranca sin maravillas iframe. Conectás las
# que uses desde el Palacio → pestaña "Maravillas" (escribe ~/.repociv/wonders/
# <id>.json) o a mano (ver docs/CUSTOM_WONDERS.md). Las VITE_WONDER_* de abajo
# solo definen los DEFAULTS de los dos ejemplos (Bibliotheca / LabHub); recién
# importan una vez que conectás ese ejemplo.

# Ejemplo Bibliotheca (La Gran Biblioteca — https://github.com/Grizaceo/la-gran-biblioteca)
# UI: host:puerto donde abres LGB en el navegador (Vite :5173). El launcher pasa
# este puerto a Vite con --strictPort, así LGB falla con un error claro en su log
# si el puerto está ocupado (en vez de derivar a 5174/5175 en silencio). Si 5173
# ya lo usa otro proyecto, cambia a uno libre (p.ej. :5180) aquí.
VITE_WONDER_BIBLIOTHECA_URL=http://127.0.0.1:5173
# Health-check del bridge — casi siempre 127.0.0.1:3001 aunque la UI sea IP Tailscale
VITE_LGB_BACKEND_URL=http://127.0.0.1:3001
# Tailscale UI: VITE_WONDER_BIBLIOTHECA_URL=http://<ip>:5173 (backend health sigue en 127.0.0.1 si mismo PC/WSL)
# Docker LGB: VITE_WONDER_BIBLIOTHECA_URL=http://127.0.0.1:3000

# Ejemplo Institutum (LabHub — https://github.com/Grizaceo/labhub)
# UI: Vite dev server :5280 (donde se monta el iframe en el mapa)
VITE_WONDER_INSTITUTUM_URL=http://127.0.0.1:5280
# API: bridge FastAPI :5281 (health checks, métricas, MCP stdio expuesto)
VITE_WONDER_INSTITUTUM_API_URL=http://127.0.0.1:5281
# Tailscale UI: VITE_WONDER_INSTITUTUM_URL=http://<ip>:5280 (API health sigue en 127.0.0.1 si mismo PC/WSL)

# Rutas de los repos hermanos (para F2 — auto-arranque). Si los movés, apuntá aquí.
# REPOCIV_WONDER_BIBLIOTHECA_DIR=~/.hermes/workspace/repos/la-gran-biblioteca
# REPOCIV_WONDER_INSTITUTUM_DIR=~/.hermes/workspace/repos/labhub

# Isolated agent execution (Fase 5 — requires Docker + built image)
# REPOCIV_AGENT_CONTAINER=1
# REPOCIV_AGENT_IMAGE=repociv-agent:latest
# Optional smoke test only: REPOCIV_CONTAINER_STUB=1
# Build image: ./scripts/build-agent-image.sh
