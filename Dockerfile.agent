FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    HOME=/tmp/workspace

RUN useradd --create-home --home-dir /tmp/workspace --shell /usr/sbin/nologin repociv

COPY server/container_entrypoint.py /opt/repociv/agent_entrypoint.py
RUN chmod 0555 /opt/repociv/agent_entrypoint.py

USER repociv
WORKDIR /tmp/workspace

ENTRYPOINT ["/opt/repociv/agent_entrypoint.py"]
