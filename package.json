{
  "name": "repociv",
  "version": "0.1.0",
  "type": "module",
  "description": "Civilization-style hex map of ~/.hermes/workspace/repos/ — agents are units, background processes are buildings",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "check": "tsc --noEmit && vitest run && vite build",
    "test:e2e": "playwright test",
    "test:e2e:list": "playwright test --list",
    "start": "bash scripts/dev-start.sh",
    "stop": "bash scripts/dev-stop.sh",
    "health": "bash scripts/healthcheck.sh",
    "backup": "bash scripts/backup-events.sh",
    "assets:3d": "bash scripts/generate-3d-textures.sh",
    "assets:office": "python3 scripts/generate-office-atlas.py",
    "assets": "npm run assets:3d && npm run assets:office",
    "lint": "eslint src --ext .ts,.tsx --max-warnings=0",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\""
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/three": "^0.175.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "knip": "^6.13.1",
    "prettier": "3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "8.59.1",
    "vite": "^6.2.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@formkit/auto-animate": "^0.9.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "lucide": "^1.16.0",
    "three": "^0.175.0",
    "valibot": "^1.3.1"
  }
}
