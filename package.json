{
  "name": "repociv",
  "version": "0.1.0",
  "type": "module",
  "description": "Civilization-style hex map of ~/.hermes/workspace/repos/ — agents are units, background processes are buildings",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc --noEmit && vitest run && vite build",
    "test:e2e": "playwright test",
    "test:e2e:list": "playwright test --list",
    "start": "bash scripts/dev-start.sh",
    "stop": "bash scripts/dev-stop.sh",
    "health": "bash scripts/healthcheck.sh",
    "backup": "bash scripts/backup-events.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "typescript": "^5.9.3",
    "vite": "^6.2.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "valibot": "^1.3.1"
  }
}
