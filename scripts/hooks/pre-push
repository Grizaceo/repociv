#!/usr/bin/env bash
# scripts/hooks/pre-push — local pre-push gate.
#
# Install with:
#   git config core.hooksPath scripts/hooks
#
# Runs scripts/check.sh before every push. Bypass with:
#   git push --no-verify
#
# We intentionally don't install hooks automatically — the user opts in.

REPO_ROOT="$(git rev-parse --show-toplevel)"
exec bash "${REPO_ROOT}/scripts/check.sh"
