{
  "name": "LEXO",
  "description": "Tensor context and memory manager. Composes context directives, performs semantic filtering, manages prompt assembly.",
  "capabilities": [
    "build_context",
    "compose_directives",
    "prune_context",
    "rank_relevance",
    "compress_memory",
    "archive_context",
    "retrieve_cached",
    "analyze_conflicts"
  ],
  "modalities": [
    "text"
  ],
  "authentication": {
    "type": "bearer",
    "header": "X-RepoCiv-Token"
  },
  "endpoint": "http://localhost:5274/api/dispatch",
  "task_lifecycle": [
    "submitted",
    "composing",
    "filtering",
    "compressing",
    "completed",
    "failed"
  ],
  "model_affinity": "claude-sonnet-4-5",
  "believability": 0.9,
  "concurrency_limit": 1,
  "default_task_type": "read",
  "timeout_s": 120,
  "retry_policy": {
    "max_attempts": 1,
    "backoff_s": 2
  },
  "metadata": {
    "role": "memory_manager",
    "tier": "EQUILIBRIO",
    "introduced_phase": "v2.0",
    "system_agent": true
  }
}
