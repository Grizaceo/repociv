{
  "name": "OPENCLAW",
  "description": "User-controlled agent with persistent memory. Executes tasks within user's workflow, respects user preferences and context.",
  "capabilities": [
    "edit_file",
    "create_file",
    "run_command",
    "execute_query",
    "read_file",
    "analyze_code",
    "test_code",
    "refactor_code"
  ],
  "modalities": [
    "text"
  ],
  "authentication": {
    "type": "bearer",
    "header": "X-RepoCiv-Token",
    "allow_user_override": true
  },
  "endpoint": "http://localhost:5274/api/dispatch",
  "task_lifecycle": [
    "submitted",
    "user_context_loading",
    "executing",
    "completed",
    "failed",
    "user_approval_required"
  ],
  "model_affinity": "claude-sonnet-4-5",
  "believability": 1.0,
  "concurrency_limit": 1,
  "default_task_type": "edit",
  "timeout_s": 600,
  "retry_policy": {
    "max_attempts": 3,
    "backoff_s": 5
  },
  "metadata": {
    "role": "user_agent",
    "tier": "EQUILIBRIO",
    "introduced_phase": "v1.0",
    "stateful": true,
    "model_recommended": true,
    "not_enforced": true
  }
}
