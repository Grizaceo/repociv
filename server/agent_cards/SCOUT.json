{
  "name": "SCOUT",
  "description": "Read-only analyst. Inspects codebases, generates diagnostics, reports issues. Stateless: no memory between missions. Works with any harness — defaults to Hermes CLI (hermes profile) but falls back through the standard cascade.",
  "capabilities": [
    "read_file",
    "list_directory",
    "search_codebase",
    "analyze_structure",
    "detect_issues",
    "generate_report",
    "measure_complexity",
    "trace_flow"
  ],
  "modalities": ["text"],
  "authentication": {
    "type": "bearer",
    "header": "X-RepoCiv-Token"
  },
  "endpoint": "http://localhost:5274/api/dispatch",
  "task_lifecycle": [
    "submitted",
    "scanning",
    "analyzing",
    "reporting",
    "completed",
    "failed"
  ],
  "harness": "hermes",
  "stateful": false,
  "believability": 0.92,
  "concurrency_limit": 2,
  "default_task_type": "read",
  "timeout_s": 600,
  "retry_policy": {
    "max_attempts": 2,
    "backoff_s": 3
  },
  "metadata": {
    "role": "analyzer",
    "tier": "ECONOMICO",
    "introduced_phase": "v1.0",
    "built_in": true,
    "read_only": true
  }
}
