{
  "name": "WORKER",
  "description": "General-purpose executor. Receives a single task, solves it in minimal tokens, and returns. Stateless by design: no memory between missions. Works with any harness — defaults to Hermes CLI (hermes profile) but falls back through the standard cascade.",
  "capabilities": [
    "edit_file",
    "create_file",
    "delete_file",
    "run_tests",
    "refactor_code",
    "format_code",
    "install_dependencies",
    "run_linter",
    "commit_changes"
  ],
  "modalities": ["text"],
  "authentication": {
    "type": "bearer",
    "header": "X-RepoCiv-Token"
  },
  "endpoint": "http://localhost:5274/api/dispatch",
  "task_lifecycle": [
    "submitted",
    "working",
    "testing",
    "completed",
    "failed"
  ],
  "harness": "hermes",
  "stateful": false,
  "believability": 0.85,
  "concurrency_limit": 3,
  "default_task_type": "edit",
  "timeout_s": 600,
  "retry_policy": {
    "max_attempts": 3,
    "backoff_s": 2
  },
  "metadata": {
    "role": "executor",
    "tier": "EQUILIBRIO",
    "introduced_phase": "v1.0",
    "built_in": true
  }
}
